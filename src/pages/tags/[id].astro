---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import Layout from '../../layouts/Layout.astro';
import BlogItem from '../../components/sections/blog/BlogItem.astro';

import { tagToSlug, getUniqueTags  } from "../../utils/tags";

export const getStaticPaths = async () => {
    const blogs = await getCollection("blogs");
    const tags = getUniqueTags(blogs);
    return tags.map((tag) => ({
        params: { id: tagToSlug(tag) },
        props: {
        tag,
        blogs: blogs
            .filter((blog) => blog.data.tags?.includes(tag))
            .sort((a, b) => b.data.datetime.valueOf() - a.data.datetime.valueOf()),
        },
    }));   
}

type Props = {
    blog: CollectionEntry<"blogs">
}

const {tag, blogs} = Astro.props;

---

<Layout title={("Blogs tagged with " + tag) as string}>
    <section class="py-12 bg-background">
        <div class="container mx-auto px-4 max-w-4xl">

            <h1 class="text-center text-3xl mb-10">Posts tagged with <span> {tag} </span>:</h1>
            <div class="space-y-6">
            {blogs.map((blog: Props, index: number) => (
                <BlogItem blog={blog} isFirst={index === 0} />
            ))}
            </div>
            
        </div>
    </section>
</Layout>
